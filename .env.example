# =============================================================================
# Aegis AI Infra — Fichier d'exemple des variables d'environnement
# =============================================================================

# --- Variables injectees dans le secret Kubernetes `aegis-env` ---
# Utilisees par Postgres/Temporal et les services applicatifs.
POSTGRES_DB=aegis_db
POSTGRES_USER=aegis_admin
POSTGRES_PASSWORD=change-me-now

# Compte applicatif initial (seed automatique via le job db-init)
AEGIS_SEED_USER_EMAIL=admin@aegis-ai.com
AEGIS_SEED_USER_PASSWORD=change-me-now

# --- Temporal Namespace ---
TEMPORAL_NAMESPACE=aegis

# --- Authentication & CORS ---
# JWT_SECRET must be shared across Brain and API Gateway for consistency.
# Use a long random string (e.g., openssl rand -base64 32).
# JWT_SECRET=GENERATED_SECRET_HERE

# Runtime mode for services that switch behavior by environment.
ENV=dev

# ALLOWED_ORIGINS: Overrides default dev origins if set.
ALLOWED_ORIGINS=http://localhost:3000,http://app.aegis.mvp.local,https://app.aegis.ai

# --- Object Storage (MinIO) ---
MINIO_ROOT_USER=aegis_minio_admin
MINIO_ROOT_PASSWORD=change-me-now
# Default buckets created at startup (comma separated)
MINIO_DEFAULT_BUCKETS=aegis-telemetry,aegis-ingest

# Client configuration for Brain and Workers
MINIO_ENDPOINT=minio:9000
MINIO_ACCESS_KEY=aegis_minio_admin
MINIO_SECRET_KEY=change-me-now
MINIO_SECURE=false
MINIO_INGEST_BUCKET=aegis-ingest

# --- Cache (Redis) ---
REDIS_PASSWORD=change-me-now

# --- Email delivery ---
# Local/dev uses Mailpit over SMTP. Production uses Resend/Brevo via HTTP.
ONBOARDING_EMAIL_ENABLED=true
SMTP_HOST=mailpit
SMTP_PORT=1025
SMTP_USERNAME=
SMTP_PASSWORD=
SMTP_USE_TLS=false
SMTP_FROM_EMAIL=team@aegis-ai.fr
FRONTEND_BASE_URL=http://localhost:3000
AEGIS_EMAIL_API_KEY=
AEGIS_EMAIL_API_URL=https://api.resend.com/emails

# --- Analytics (ClickHouse) ---
CLICKHOUSE_PASSWORD=change-me-now

# --- Graph Database (Neo4j) ---
NEO4J_PASSWORD=change-me-now
