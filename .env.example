# =============================================================================
# Aegis AI Infra — Fichier d'exemple des variables d'environnement
# =============================================================================

# --- Variables injectees dans le secret Kubernetes `aegis-env` ---
# Utilisees par Postgres/Temporal et les services applicatifs.
POSTGRES_DB=aegis_db
POSTGRES_USER=aegis_admin
POSTGRES_PASSWORD=change-me-now
# Temporal requiert aussi spécifiquement cette clé "password" pour initialiser ses tables :
password=change-me-now

# Compte applicatif initial (seed automatique via le job db-init)
AEGIS_SEED_USER_EMAIL=admin@aegis-ai.com
AEGIS_SEED_USER_PASSWORD=change-me-now

# --- Temporal Namespace ---
TEMPORAL_NAMESPACE=default

# --- Authentication & CORS ---
# JWT_SECRET must be shared across Brain and API Gateway for consistency.
JWT_SECRET=change-me-to-a-long-random-string

# ALLOWED_ORIGINS: Overrides default dev origins if set.
ALLOWED_ORIGINS=http://localhost:3000,http://app.aegis.mvp.local,https://app.aegis.ai
