# =============================================================================
# Aegis AI Infra — Fichier d'exemple des variables d'environnement
# =============================================================================

# --- PostgreSQL Database ---
# Ces variables sont envoyées à Kubernetes lors de l'installation de ta BDD.
# POSTGRES_PASSWORD est indispensable, c'est le mot de passe maître de la BDD.
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=aegis_db
POSTGRES_USER=aegis_admin
POSTGRES_PASSWORD='TonSuperPasswordSecurise'

# --- Temporal Orchestrator ---
# L'adresse utilisée par ton API Go et ton Brain Python pour parler au moteur de Workflows
TEMPORAL_HOST=localhost:7233
TEMPORAL_PORT=7233
TEMPORAL_NAMESPACE=default

# --- URL de l'API Gateway (Pour ton Front-end) ---
# Le port 32564 est le NodePort de ton Ingress Nginx qu'on avait vu ensemble il y a quelques jours
VITE_API_URL=http://localhost:32564
# VITE_API_URL=http://api.aegis.pre-alpha.local:32564  # Variante avec le DNS local
