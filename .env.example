# =============================================================================
# Aegis AI Infra — Fichier d'exemple des variables d'environnement
# =============================================================================

# --- PostgreSQL Database ---
# Ces variables sont envoyées à Kubernetes lors de l'installation de ta BDD.
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=aegis_db
POSTGRES_USER=aegis_admin
POSTGRES_PASSWORD=password123
# Temporal requiert aussi spécifiquement cette clé "password" pour initialiser ses tables :
password=password123

# --- Temporal Orchestrator ---
TEMPORAL_HOST=localhost:7233
TEMPORAL_PORT=7233
TEMPORAL_NAMESPACE=default

# --- URL de l'API Gateway (injectée dans le pod Dashboard via le secret aegis-env) ---
API_GATEWAY_URL=http://api.aegis.pre-alpha.local:32564
INTERNAL_API_URL=http://api-gateway-mvp:8080/
