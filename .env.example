# =============================================================================
# Aegis AI Infra — Environment Variables (DEV ONLY)
# =============================================================================
# Copy this file to .env and fill in the values.
# NEVER commit .env — it is listed in .gitignore.
#
# Usage: scripts automatically source this file.
#        You can also load it manually: source .env
# =============================================================================

# --- PostgreSQL ---
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=aegis_db
POSTGRES_USER=aegis_admin
POSTGRES_PASSWORD='password123'

# --- Temporal ---
TEMPORAL_HOST=localhost:7233
TEMPORAL_PORT=7233
TEMPORAL_NAMESPACE=default

# --- ArgoCD ---
ARGOCD_SERVER=localhost:8080
ARGOCD_ADMIN_PASSWORD=   # run: kubectl -n argocd get secret argocd-initial-admin-secret -o jsonpath="{.data.password}" | base64 -d

# --- GitHub Container Registry (GHCR) ---
GHCR_USERNAME=           # your GitHub username
GHCR_TOKEN=              # GitHub PAT with read:packages scope

# --- API Gateway / Microservices Local Overrides ---
# These simulate the internal K8s DNS to point to your localhost port-forward
DB_HOST=localhost:5432
