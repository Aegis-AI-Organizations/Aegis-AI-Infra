authorityKeyIdentifier=keyid,issuer
basicConstraints=CA:FALSE
keyUsage = digitalSignature, nonRepudiation, keyEncipherment, dataEncipherment
subjectAltName = @alt_names
[alt_names]
DNS.1 = aegis-temporal-mvp-frontend
DNS.2 = aegis-temporal-mvp-frontend.aegis-system
DNS.3 = aegis-temporal-mvp-frontend.aegis-system.svc.cluster.local
DNS.4 = localhost
