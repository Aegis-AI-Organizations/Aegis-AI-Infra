# Database Configuration
POSTGRES_DB=aegis
POSTGRES_USER=aegis
POSTGRES_PASSWORD=aegis_password

# Aegis Seed User
AEGIS_SEED_USER_EMAIL=admin@aegis-ai.com
AEGIS_SEED_USER_PASSWORD=admin_password

# Brain Configuration
TEMPORAL_NAMESPACE=default
JWT_SECRET=supersecretjwtkey
GRPC_PORT=50051

# API Gateway Configuration
PORT=8080
ALLOWED_ORIGINS=http://localhost,http://localhost:3000

# Dashboard Configuration
VITE_API_URL=http://localhost:8080/api
FRONTEND_BASE_URL=http://localhost:3000

# Local onboarding emails (Mailpit)
ONBOARDING_EMAIL_ENABLED=true
SMTP_HOST=mailpit
SMTP_PORT=1025
SMTP_USERNAME=
SMTP_PASSWORD=
SMTP_USE_TLS=false
SMTP_FROM_EMAIL=onboarding@aegis-ai.local

# Object Storage (MinIO)
MINIO_ROOT_USER=minio_admin
MINIO_ROOT_PASSWORD=minio_password
MINIO_DEFAULT_BUCKETS=aegis-telemetry,aegis-ingest

# MinIO Client (Brain/Workers)
MINIO_ENDPOINT=minio:9000
MINIO_ACCESS_KEY=minio_admin
MINIO_SECRET_KEY=minio_password
MINIO_SECURE=false
MINIO_INGEST_BUCKET=aegis-ingest

# Cache (Redis)
REDIS_PASSWORD=redis_password
