# Database Configuration
POSTGRES_DB=aegis_db
POSTGRES_USER=aegis_admin
POSTGRES_PASSWORD=aegis_password

# Aegis Seed User
AEGIS_SEED_USER_EMAIL=admin@aegis-ai.com
AEGIS_SEED_USER_PASSWORD=admin_password

# Brain Configuration
ENV=production
TEMPORAL_NAMESPACE=default
JWT_SECRET=supersecretjwtkey
GRPC_PORT=50051

# API Gateway Configuration
PORT=8080
ALLOWED_ORIGINS=http://localhost:3000,http://app.aegis.mvp.local

# Dashboard Configuration
VITE_API_URL=/api

# Object Storage (MinIO)
MINIO_ROOT_USER=minio_admin
MINIO_ROOT_PASSWORD=minio_password
MINIO_DEFAULT_BUCKETS=aegis-telemetry,aegis-ingest

# MinIO Client (Brain/Workers)
MINIO_ENDPOINT=minio:9000
MINIO_ACCESS_KEY=minio_admin
MINIO_SECRET_KEY=minio_password
MINIO_SECURE=false
MINIO_INGEST_BUCKET=aegis-ingest

# Cache (Redis)
REDIS_PASSWORD=redis_password

# Email delivery
